{
  "name": "hfcl-app",
  "private": true,
  "scripts": {
    "build": "pnpm --filter hfcl-client build && pnpm --filter hfcl-apis build",
    "build:client": "pnpm --filter hfcl-client build",
    "build:server": "pnpm --filter hfcl-apis build",
    "dev:client": "pnpm --filter hfcl-client dev",
    "dev:server": "pnpm --filter hfcl-apis start:dev",
    "start:server": "pnpm --filter hfcl-apis start",
    "start:client": "pnpm --filter hfcl-client serve"
  }
}
